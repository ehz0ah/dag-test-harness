# Copy this file to your scratch env file, for example:
#   cp .env.example /path/to/loop/.ovtest/.env
# Then replace placeholder values before running live cases.

# Shared ARK key used by OpenViking LLM/VLM, embeddings, Hermes, and ovtest judges.
ARK_API_KEY=replace-with-your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenViking/Hermes runtime model.
ARK_MODEL=doubao-seed-evolving

# ovtest judge model. Better models are used for better semantic evaluation.
OVTEST_JUDGE_MODEL=glm-5-2-260617

# Local loop workspace paths. Adjust these for your machine.
OV_TEST_STATE_DIR=/path/to/loop/.ovtest
OV_TEST_CONF_DIR=/path/to/loop/.ovtest/openviking
OV_TEST_OPENVIKING_CONF=/path/to/loop/.ovtest/openviking/ov.conf
OV_TEST_OV_BIN=/path/to/loop/OpenViking/.venv/bin/ov
OV_TEST_HERMES_BIN=/path/to/loop/hermes-agent/.venv/bin/hermes
OV_TEST_HERMES_HOME_TEMPLATE=/path/to/loop/.ovtest/hermes/template

# Local OpenViking test identity recreated after each storage reset.
OV_TEST_ACCOUNT_ID=loop-ovtest
OV_TEST_USER_ID=hermes
OV_TEST_USER_KEY_SEED=loop-ovtest-hermes

# Live subprocess bounds.
OV_TEST_CASE_TIMEOUT=1800
OV_TEST_CLI_TIMEOUT=300
OV_TEST_HERMES_TIMEOUT=300
OV_TEST_CODEX_TIMEOUT=900

# Judge calls are real gates for semantic cases. Keep enough time for provider
# latency, but fail clearly when the judge endpoint is unhealthy.
OVTEST_JUDGE_TIMEOUT=120
OVTEST_JUDGE_RETRIES=1

# Local workflow: stop the OpenViking server, then run:
#   go run ./cmd/ovtest reset-local-state
# Normal case runs do not do API cleanup. For remote/shared servers where local
# file reset is impossible, opt in explicitly:
OV_TEST_CLEANUP_MODE=none
# OV_TEST_CLEANUP_MODE=api
# OV_TEST_CLEANUP_URIS=viking://user/hermes,viking://resources/ovtest-codex

# Remote resource case. Defaults to a small public GitHub markdown file when
# unset; override when you need a project-owned public fixture.
OV_TEST_REMOTE_RESOURCE_URL=https://fastly.jsdelivr.net/gh/ehz0ah/Celeste@5b8ab7f10d104e23ad12db68dc228e1606a6bcb6/README.md
OV_TEST_REMOTE_RESOURCE_EXPECT=celeste fpga,basys3 fpga board

# Codex/OpenViking live cases. Defaults use `codex` from PATH and the shared
# OpenViking ovcli.conf user key.
# OV_TEST_CODEX_BIN=/path/to/codex
# OV_TEST_CODEX_MODEL=
# OV_TEST_CODEX_OPENVIKING_URL=http://127.0.0.1:1933
# OV_TEST_CODEX_OPENVIKING_API_KEY=
