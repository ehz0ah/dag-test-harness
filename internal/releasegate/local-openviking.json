{
  "server": {
    "host": "127.0.0.1",
    "workers": 1,
    "auth_mode": "api_key",
    "root_api_key": null
  },
  "storage": {
    "workspace": "./data",
    "vectordb": {
      "name": "context",
      "backend": "local",
      "project": "ovtest"
    },
    "agfs": {
      "backend": "local",
      "timeout": 10
    }
  },
  "embedding": {
    "dense": {
      "provider": "volcengine",
      "model": "$OPENVIKING_EMBEDDING_MODEL",
      "api_key": "$OPENVIKING_EMBEDDING_API_KEY",
      "api_base": "$OPENVIKING_EMBEDDING_BASE_URL",
      "dimension": 1024,
      "input": "multimodal"
    },
    "max_concurrent": 2,
    "text_source": "content_only",
    "max_input_tokens": 4096
  },
  "vlm": {
    "provider": "volcengine",
    "model": "$OPENVIKING_LLM_MODEL",
    "api_key": "$OPENVIKING_LLM_API_KEY",
    "api_base": "$OPENVIKING_LLM_BASE_URL",
    "temperature": 0.0,
    "max_retries": 2,
    "thinking": false
  },
  "retrieval": {
    "hotness_alpha": 0.0,
    "score_propagation_alpha": 1.0
  },
  "auto_generate_l0": true,
  "auto_generate_l1": true,
  "default_search_mode": "thinking",
  "default_search_limit": 3,
  "memory": {
    "version": "v2",
    "extraction_enabled": true,
    "session_skill_extraction_enabled": false
  },
  "log": {
    "level": "INFO",
    "output": "stdout"
  }
}
